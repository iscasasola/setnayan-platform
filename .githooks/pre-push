#!/bin/sh
# Pre-push migration guard. Inspects the COMMITS BEING PUSHED (stdin) vs
# origin/main — NOT the working tree — so it catches a cross-branch collision
# before the push lands and never false-blocks on unrelated WIP. Two rules,
# mirroring CI's "migration timestamp guard" + `pnpm migration:check`:
#   RULE 1  no two migrations share a 14-digit prefix (a dup is the PK in
#           supabase_migrations.schema_migrations → `supabase db push` half-applies
#           prod then crashes on the dup, and CI blocks every open PR).
#   RULE 2  a NEW migration (pushed, not yet on origin/main) must NOT use a
#           hand-typed YYYYMMDD000000 round prefix — that is HOW parallel branches
#           collide (each passes CI alone, then clash on merge). `pnpm migration:new`
#           hands out a collision-resistant, never-round prefix.
# Pure POSIX sh — runs under git's bundled shell on macOS / Linux / Windows.
# Migration filenames never contain spaces, so word-splitting below is safe.

root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -d "$root/supabase/migrations" ] || exit 0

zero="0000000000000000000000000000000000000000"
pushed=""
got_stdin=0

# git feeds one line per pushed ref: "<local-ref> <local-sha> <remote-ref> <remote-sha>".
while read -r _lref lsha _rref _rsha; do
  got_stdin=1
  [ -n "$lsha" ] || continue
  [ "$lsha" = "$zero" ] && continue   # branch deletion — nothing to add
  pushed="$pushed
$(git ls-tree -r --name-only "$lsha" -- supabase/migrations 2>/dev/null)"
done

# Fallback when nothing arrived on stdin (e.g. invoked by hand): use HEAD.
if [ "$got_stdin" -eq 0 ]; then
  pushed="$(git ls-tree -r --name-only HEAD -- supabase/migrations 2>/dev/null)"
fi

# origin/main basenames so we can tell a NEW migration from a grandfathered one.
main_names=""
if git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
  main_names="$(git ls-tree -r --name-only origin/main -- supabase/migrations 2>/dev/null | sed 's#.*/##')"
fi

pushed_names=$(printf '%s\n' "$pushed" | sed 's#.*/##' | grep -E '^[0-9]{14}_' | sort -u)
main_prefixes=$(printf '%s\n' "$main_names" | grep -oE '^[0-9]{14}' | sort -u)

# --- RULE 1: a 14-digit prefix used by two different files across pushed ∪ main.
dups=$(printf '%s\n%s\n' "$pushed_names" "$main_names" \
  | grep -E '^[0-9]{14}_' | sort -u | grep -oE '^[0-9]{14}' | sort | uniq -d)

# --- RULE 2: a pushed migration with a hand-typed round prefix that is NOT yet
#     on origin/main (i.e. brand-new in this push).
handtyped=""
for f in $(printf '%s\n' "$pushed_names" | grep -E '^[0-9]{8}000000_'); do
  p=$(printf '%s' "$f" | grep -oE '^[0-9]{14}')
  printf '%s\n' "$main_prefixes" | grep -qx "$p" || handtyped="$handtyped $f"
done

fail=0
if [ -n "$dups" ]; then
  fail=1
  echo "" >&2
  echo "✗ Push blocked — RULE 1: duplicate Supabase migration timestamp prefix(es):" >&2
  for p in $dups; do
    echo "    $p" >&2
    printf '%s\n%s\n' "$pushed_names" "$main_names" | grep "^${p}_" | sort -u | sed 's#^#      - supabase/migrations/#' >&2
  done
  echo "  A duplicate prefix half-applies prod on \`supabase db push\` then crashes on the dup." >&2
fi
if [ -n "$handtyped" ]; then
  fail=1
  echo "" >&2
  echo "✗ Push blocked — RULE 2: hand-typed round prefix on a new migration:" >&2
  for f in $handtyped; do echo "      - supabase/migrations/$f" >&2; done
  echo "  YYYYMMDD000000 prefixes collide across parallel branches (the dup root cause)." >&2
fi
if [ "$fail" -eq 1 ]; then
  echo "" >&2
  echo "  Fix: let the allocator hand out a safe, never-round prefix —" >&2
  echo "    pnpm migration:new \"<name>\"   # then move your SQL into the file it creates" >&2
  echo "" >&2
  exit 1
fi

exit 0
