# Tayo Web — local development environment
#
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# Per the 0013 Platform Stack & Sync spec, every credential below comes
# from a specific Section A step the user runs in the cloud console.
#
# Production secrets live in Vercel / Cloudflare environment variables,
# not this file. This file is the local-dev contract only.

# ─── Supabase (Step A4) ─────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service-role key — server-side only (admin client + Edge Functions).
# Never expose to the browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Tayo guest-session signing key ─────────────────────────────────────────
# Used by lib/server/guest-session.ts to sign the guest magic-link cookie.
# Generate with `openssl rand -hex 32`. Min 32 chars.
EVENTS_TOKEN_SECRET=replace-with-openssl-rand-hex-32-output

# ─── Cloudflare R2 (Step A5) ────────────────────────────────────────────────
# Used by lib/r2 (signed-URL helpers, photo/clip uploads from the native apps,
# reel renders). Used by Edge Functions; the web app reads object URLs only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tayo-photos
R2_PUBLIC_HOSTNAME=cdn.tayo.app

# ─── PayMongo (Step A7) — PHP card / GCash / Maya ───────────────────────────
PAYMONGO_PUBLIC_KEY=pk_test_...
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_WEBHOOK_SECRET=

# ─── Stripe (Step A8) — international card ──────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Anthropic Claude API (Step A9) — Tayo Kasalan AI assistant ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (Step A13) — transactional email ────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=hello@tayo.app

# ─── YouTube Data API (Step A6) — Live Stream broadcasts ────────────────────
# OAuth refresh token for Tayo's master @TayoWeddings channel. Edge Function
# uses this to create broadcasts on couples' behalf.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ─── Cloudflare Stream (Step A5 — Live Stream ingest) ───────────────────────
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Twilio (Step A14, optional in V1 — SMS RSVP reminders) ─────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─── Sentry (Step A14) — error tracking ─────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── PostHog — analytics + session replay ───────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Suno (Step A15) — music catalogue generation (offline pipeline) ────────
# Not used at runtime; referenced by the music-catalogue cowork playbook.
# SUNO_API_KEY=

# ─── Site origin (used for QR canonical URLs) ───────────────────────────────
# Pulled from request headers in dev; set explicitly in prod for absolute URLs.
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000
