# Setnayan — Sprint 0 environment template
# Copy to .env.local and fill in real values. Never commit .env.local.
# Source: 0013_platform_stack_and_sync + API_Integration_Checklist.md

# ----------------------------------------------------------------------
# Supabase — Singapore region (closest to PH, ~50ms to Manila/Cebu/Davao)
# ----------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------
# Cloudflare R2 — PH region buckets
# Buckets: setnayan-media · setnayan-thread-files ·
# setnayan-vendor-contracts · setnayan-samples ·
# setnayan-vendor-verification (90d rolling raw + 7yr audit per BIR § 235)
# ----------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_MEDIA=setnayan-media
R2_BUCKET_THREAD_FILES=setnayan-thread-files
R2_BUCKET_VENDOR_CONTRACTS=setnayan-vendor-contracts
R2_BUCKET_SAMPLES=setnayan-samples
R2_BUCKET_VENDOR_VERIFICATION=setnayan-vendor-verification
# Iteration 0026 — BIR Form 2307 quarterly PDFs (10-year retention).
# Owner action: provision a new R2 bucket and paste its name here.
R2_BUCKET_BIR_2307=setnayan-bir-2307
# Public base URL for the `media` bucket (the ONLY publicly-served bucket:
# hero scrub frames, vendor/service photos, profile photos, merchant QR).
# Must be a PUBLIC host bound to setnayan-media — a custom domain
# (e.g. https://media.setnayan.com) or the bucket's r2.dev dev subdomain
# (e.g. https://pub-<hash>.r2.dev). Objects resolve at `${R2_PUBLIC_URL}/<key>`
# (NO bucket segment — Cloudflare public bucket URLs bind to one bucket).
# ⚠ Do NOT set this to the S3 API endpoint
# (https://<account>.r2.cloudflarestorage.com) — that requires SigV4-signed
# requests and 400s a plain browser <img> GET, so every public image breaks.
R2_PUBLIC_URL=

# ----------------------------------------------------------------------
# Cloudflare Realtime TURN — WebRTC relay for all P2P surfaces
# ----------------------------------------------------------------------
# Powers the Live Studio DEMO, the real Live Studio (operator phones →
# control room), and vendor↔couple calls — every peer-to-peer WebRTC path.
# Public STUN alone can't traverse symmetric NAT / CGNAT (PH mobile data,
# client-isolated venue/guest Wi-Fi) — that's why the demo synced for some
# phones and not others, and why a mobile-data camera operator drops. A TURN
# relay lets those hard-NAT pairs connect. Only the minority of connections
# that can't go peer-to-peer relay through it, so cost is bounded
# (~$0.05/GB relayed; 1,000 GB/mo free).
#
# Owner action: Cloudflare dashboard → Realtime → TURN → create a TURN key,
# then paste its Key ID + API token here. UNSET = STUN-only (every surface
# keeps its connect-or-fail-gracefully behavior; no relay, no bill).
# The API token is server-only — it is NEVER shipped to the browser; the app
# mints short-lived per-connection credentials from it (see lib/turn.ts).
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=

# ----------------------------------------------------------------------
# Daily.co — RETIRED 2026-05-16 (spec corpus a0fa3c7)
# Video meetings feature removed; vendor↔couple chat covers consult flow.
# Vars left commented out so partial .env.local files don't crash on
# typed lookups. Remove entirely in a future cleanup.
# ----------------------------------------------------------------------
# DAILY_API_KEY=
# DAILY_DOMAIN=

# ----------------------------------------------------------------------
# Resend — transactional email (iteration 0028)
# ----------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_ADDRESS=hello@setnayan.com

# ----------------------------------------------------------------------
# Web Push — PWA push notifications (compliance/push-offline, iter 0028/0031)
# ----------------------------------------------------------------------
# Generate the keypair ONCE with:  npx web-push generate-vapid-keys
# Paste the "Public Key" below (also exposed to the browser via the
# NEXT_PUBLIC_ prefix so the client can subscribe) and the "Private Key" into
# VAPID_PRIVATE_KEY. No Apple/Google developer account is needed — Web Push
# rides the browser's own Push Service. When these are UNSET, push simply
# no-ops everywhere (the in-app notification + email still fire) and the build
# and site work unchanged.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI for the push subscription (mailto: or https:). Push Services use
# it to reach you about delivery issues. Defaults to mailto:hello@setnayan.com.
VAPID_SUBJECT=mailto:hello@setnayan.com

# ----------------------------------------------------------------------
# Observability (iteration 0035 — Sentry + PostHog + Better Stack)
# ----------------------------------------------------------------------
SENTRY_DSN=
# Client-side DSN read by apps/web/app/_components/deferred-observability.tsx
# to lazy-init the browser SDK after hydration (see iteration 0035 for the
# perf rationale — Sentry SDK chunk is ~105kB gzipped, deferred to idle so
# it doesn't dominate LCP). Same DSN value as SENTRY_DSN above. NEXT_PUBLIC_
# prefix is required so Next.js inlines it into the client bundle at build
# time. Without this, browser-side errors are NOT reported.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
BETTER_STACK_SOURCE_TOKEN=

# ----------------------------------------------------------------------
# App-level
# ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Search-engine site-verification (SEO · optional). Paste the token strings from
# Google Search Console and Bing Webmaster Tools to verify domain ownership via
# meta tag (app/layout.tsx baseMetadata.verification). Unset → no meta emitted.
# GSC feeds Google AI Overviews; Bing feeds Copilot — verify both.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Three-tier public-URL cutover (slug-routing program, PR6). OFF by default.
# When "true", the canonical public event URL flips from the legacy bare root
# setnayan.com/{event-slug} to the nested setnayan.com/u/{owner-slug}/{event-slug}:
# new QRs/links/shares emit the nested form, and old bare-root URLs (printed QRs)
# 307-redirect to it. Flip only AFTER a production bake. Reversible — flipping
# back to unset/"false" restores bare-root canonical (the 307s aren't cached).
# NB: NEXT_PUBLIC_ = build-time inlined, so a change needs a redeploy to take
# effect (Vercel redeploys on env change anyway).
NEXT_PUBLIC_U_NESTING_CUTOVER=

# Pilot mode — make EVERY paid SKU resolve to ₱0 until the timestamp
# below. ISO 8601 with a timezone offset (e.g. "2026-08-31T23:59:59+08:00"
# for end of Aug 2026 PH time). Used for closed pilot testing so couples
# + vendors can exercise the full checkout → activation → expiry → cancel
# cycle without money actually moving. Unset / empty / invalid value =
# pilot mode OFF (production behavior). Sitewide banner appears
# automatically when active. Orthogonal to the launch promo
# (LAUNCH_PROMO_UNTIL is a separate per-SKU window for the 16 zero-cost
# SKUs through 2027-03-31).
NEXT_PUBLIC_PILOT_MODE_FREE_UNTIL=

# OAuth provider gates. The V1 OAuth set is Google + Apple + Facebook
# (Facebook was removed 2026-06-15 and RE-ADDED 2026-07-21 by owner
# directive; Apple was promoted out of its earlier V1.1 deferral). Each
# flag controls whether the matching "Continue with Google" / "Continue
# with Apple" / "Continue with Facebook" button renders on /login +
# /signup. Default to empty (= OFF) so a freshly-cloned dev
# env (and prod before owner-side credentials are pasted into Supabase
# Studio) doesn't 404 when users click the buttons. Once you've completed
# OWNER_ACTIONS.md Phase 2D for a provider — pasted the OAuth client into
# Supabase Studio Auth → Providers → ${provider} — flip the matching flag
# here to "true" and the button starts rendering. Apple additionally
# requires Apple Developer Program enrollment ($99/yr) for the Services
# ID + client-secret JWT.
# Facebook additionally requires the Meta app to be switched from
# Development to LIVE mode — in Development mode only people with a role
# on the app can complete the login.
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=
NEXT_PUBLIC_OAUTH_APPLE_ENABLED=
NEXT_PUBLIC_OAUTH_FACEBOOK_ENABLED=

# Anon-draft onboarding (2026-06-20). When "true", a visitor can FINISH
# onboarding with NO sign-in: the commit action mints a Supabase native
# anonymous session, saves their event under it, and drops them in the
# dashboard with a "secure your plan" banner that converts the same uid to a
# permanent account on signup. Default OFF. Two owner go-live steps BEFORE
# flipping this true, or anonymous sign-in will fail:
#   1. Supabase Auth dashboard → enable "Allow anonymous sign-ins".
#   2. Apply migration 20270205204166_anon_onboarding_null_email_trigger.sql
#      (makes the user-creation trigger tolerate the null email anon users have).
NEXT_PUBLIC_ANON_ONBOARDING_ENABLED=

# Onboarding V2 brief — profile prefill (2026-07-13). When "true", onboarding
# reads the four self-consented profile facts (religion / civil status /
# birthdate / gender) off public.users and PREFILLS the per-type questions they
# already answer (e.g. a Catholic's christening rite), asking only what's still
# missing. Default OFF keeps every onboarding flow byte-identical. No migration —
# it prefills from columns that already exist. SELF facts only; dependent-subject
# prefill stays behind NEXT_PUBLIC_DEPENDENT_PEOPLE. Flip in .env.local (dev) /
# Vercel (preview·prod) to enable.
NEXT_PUBLIC_ONBOARDING_V2_BRIEF_ENABLED=

# Papic Games / Photo Challenge (2026-07-22). Gates the WHOLE feature — auto booth
# missions from event_vendors, the guest capture-surface challenge panel + §4
# consent tap, the custom vendor challenge (vendor authoring + couple approval),
# and the "Photo Challenges" line on the guest landing page. Default OFF: nothing
# renders and no missions/completions are written until this is set. NEXT_PUBLIC_ is
# BUILD-TIME INLINED into every bundle, so a bare env flip does NOTHING until a
# REDEPLOY (fails safe — never half-open). Set to 'true' in Vercel + redeploy to
# launch. See 0012_papic/Papic_Games_and_Vendor_Missions_Spec_2026-07-21.md.
NEXT_PUBLIC_PAPIC_GAMES_V1=

# Cloudflare Turnstile SITE key (2026-07-03). Enabling anonymous sign-ins opens a
# bot-abuse vector Supabase warns about; the fix is Supabase's GLOBAL captcha,
# which then requires a captcha token on EVERY auth call (login / signup /
# change-password re-auth / anonymous sign-in). Set this to the Turnstile widget's
# SITE key and <TurnstileField> starts minting tokens across all those forms.
# EMPTY → the widget renders nothing and every auth call behaves exactly as before
# (strict no-op) — so this is safe to leave blank until you activate captcha.
# The Turnstile SECRET key is NOT set here — it goes into Supabase's captcha config
# (that's where GoTrue verifies the token). See OWNER_ACTIONS.md for the safe
# activation order (set this + redeploy FIRST, THEN enable captcha in Supabase).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Guided "create a service" wizard (vendor Services builder redesign, 2026-06-20).
# When "true", the vendor Services left-rail picker opens the step-by-step
# create-a-service flow (/services/new/<category>) instead of the legacy inline
# ?add= form; the flow saves via the atomic save_vendor_service RPC.
# LIVE by default (migration 20270208451790 applied 2026-06-21). Set to "false"
# to fall back to the legacy inline form. (The legacy edit card is kept regardless.)
NEXT_PUBLIC_SERVICE_WIZARD_ENABLED=

# Named Calendars rework (owner 2026-06-20). When "true", a service's schedule
# pool is resolved from its named-calendar membership
# (vendor_schedule_calendar_services) instead of its category — vendors name
# calendars + pick which services they cover. Bundle legs stay category-resolved;
# an unassigned service falls back to its category pool (stays bookable). The
# pool entity + capacity + acquire RPC are UNCHANGED, and after the Phase A
# backfill each service's calendar pool == its category pool, so flag-on returns
# identical pool_ids. Phase A (resolver + migration) + Phase B (the Calendar UI)
# are both shipped. LIVE by default (migration 20270209750853 applied + backfilled
# 2026-06-21; conservation check = 0 orphaned booking pools). Set to "false" to
# revert to auto per-category schedules.
NEXT_PUBLIC_NAMED_CALENDARS_ENABLED=

# Vendor declared + DTI-verified experience (service-card trust signal, 2026-06-20).
# When "true": vendors declare "in business since YYYY" + "approx weddings done"
# on their profile; admins confirm the year against the DTI doc in the
# verification queue (stamps a verified badge); the couple-facing vendor page
# shows "N yrs in business · M+ weddings" with a verified check or "self-reported".
# LIVE by default (migration 20270209420471 applied 2026-06-21). Set to "false"
# to disable the declare/verify/display surfaces.
NEXT_PUBLIC_VENDOR_EXPERIENCE_ENABLED=

# Proactive bundle nudge in the inquiry composer (2026-06-20). When "true", a
# multi-service vendor's "also ask about" section is reframed as a bundle ask
# ("X also offers these — add any and ask for one bundle price") with a "request
# one bundle price" toggle; that intent is appended to the first inquiry message
# so the vendor knows to quote the services as one deal. Pure UI + message (no
# schema). LIVE by default (2026-06-21). Set to "false" to revert to the plain
# "also ask about" checkboxes.
NEXT_PUBLIC_BUNDLE_NUDGE_ENABLED=

# Secret for signing guest invitation cookies (iteration 0002). Generate with:
#   openssl rand -hex 32
# If not set, the app falls back to SUPABASE_SERVICE_ROLE_KEY (acceptable for
# V1 but rotate to a dedicated secret post-launch).
GUEST_SESSION_SECRET=

# Salt for the de-identified viewer hash on vendor_profile_views (Wave 6
# Quote-to-Booking Funnel). The viewer's user-id / anon-session-id is stored
# ONLY as sha256(VIEWER_HASH_SALT || id) — never raw. Generate with:
#   openssl rand -hex 32
# If not set, falls back to SUPABASE_SERVICE_ROLE_KEY (acceptable for V1; the
# hash is still non-reversible — rotate to a dedicated salt post-launch).
VIEWER_HASH_SALT=

# ----------------------------------------------------------------------
# Cron / scheduled jobs (iteration 0026 BIR Form 2307 quarterly cron)
# Shared secret between Supabase pg_cron and the
# /api/admin/cron/generate-2307 endpoint. Owner-side setup:
#   1. Generate: openssl rand -hex 32
#   2. Paste here + into Vercel env.
#   3. Run in Supabase SQL Editor:
#        ALTER DATABASE postgres SET app.cron_secret = '<value>';
#        ALTER DATABASE postgres SET app.app_url    = 'https://www.setnayan.com';
# Without this, the cron job will fail with 401.
# ----------------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------------
# Anthropic Claude API (V1 SKU lock 2026-05-16, spec corpus a0fa3c7)
# Owner-side setup pending. Primary model handles drafting + reasoning;
# budget model handles cheap classification + cache-friendly tail calls.
# Spend caps enforced server-side via the Claude API integration layer.
# ----------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-6

# OpenAI Moderation API — free, used only for editorial content scanning
# (vulgarity / hate speech detection before editorial is shown to couple)
# Sign up at platform.openai.com — moderation endpoint is always free.
OPENAI_API_KEY=
ANTHROPIC_BUDGET_MODEL=claude-haiku-4-5
ANTHROPIC_SPEND_CAP_MONTHLY_USD=2000
ANTHROPIC_SPEND_ALERT_MONTHLY_USD=500
ANTHROPIC_SPEND_ALERT_DAILY_USD=100

# ----------------------------------------------------------------------
# Recraft V3+ vector-illustration API (V1 Wedding Attire Guide library)
# Owner directive 2026-05-23 PM third pass: generate 5-style × 10-role
# Filipino-clipart figure library via Recraft V3+ native SVG output.
# Sign up at https://www.recraft.ai/ → Account → API Tokens. Pre-purchase
# at least $4 of API units (1000 units = $1; vector image = 80 units;
# 50 SVGs = ~$4).
#
# TWO consumers:
#   1. apps/web/scripts/generate-attire-guide-figures.ts — offline batch run
#      by the Setnayan team (Wedding Attire Guide library → static SVGs in R2).
#   2. RUNTIME (added 2026-06-11): the Setnayan-AI Bespoke Monogram studio
#      (/dashboard/[eventId]/monogram) calls this PER COUPLE REQUEST via
#      lib/bespoke-monogram.ts → 4 native-SVG marks per round, ~US$0.32/round,
#      capped at 12 rounds/event. The studio DEGRADES GRACEFULLY when the key
#      is unset (bespokeStudioEnabled() → false → the studio hides itself and
#      the curated lockups still work), so this is optional for a deploy that
#      doesn't want the bespoke studio. Set it in Vercel to enable the studio.
# See 02_Specifications/Wedding_Attire_Guide_AI_Generation.md for the offline
# prompt template; the studio prompts live in lib/bespoke-monogram-engine.ts.
# ----------------------------------------------------------------------
RECRAFT_API_KEY=

# ----------------------------------------------------------------------
# Maya Business gateway — V1.5+ (spec corpus a0fa3c7)
# Drives Maya QR Ph + GCash Direct + Credit Card rails. OAuth flow not
# yet wired; vars listed so .env.local templates stay in sync.
# ----------------------------------------------------------------------
MAYA_BUSINESS_API_KEY=
MAYA_BUSINESS_REGION=ph
MAYA_BUSINESS_QR_ENABLED=true

# ----------------------------------------------------------------------
# Persona — vendor ID verification (V1 SKU lock 2026-05-16)
# Government ID + liveness check. Template ID drives the inquiry form
# the vendor sees; API key is server-side only.
# ----------------------------------------------------------------------
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=

# ----------------------------------------------------------------------
# AMLC sanctions screening (V1 SKU lock 2026-05-16)
# Optional: if unset, the vendor-verification flow falls back to manual
# admin lookup. Either way the result lands in
# vendor_verifications.sanctions_clear / .sanctions_screened_at.
# ----------------------------------------------------------------------
AMLC_API_KEY=


# ----------------------------------------------------------------------
# Iteration 0017 — Patiktok worker + TikTok OAuth (Phase 2-3)
# ----------------------------------------------------------------------
# INTERNAL_WORKER_SECRET: shared secret protecting the Patiktok render
# worker route (/api/internal/patiktok/process-job). Supabase pg_cron
# passes it as `Authorization: Bearer ...` on its scheduled POST.
INTERNAL_WORKER_SECRET=

# TIKTOK OAuth credentials (Personal-tier 1,999/day -- couple BYO TikTok).
# Owner action: sign up at developers.tiktok.com, register a Setnayan app,
# add the callback URL (e.g. https://www.setnayan.com/api/tiktok/auth/callback)
# as a Redirect URI. Scopes requested: user.info.basic + video.upload +
# video.publish.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=

# Long-lived refresh token for the master @SetnayanWeddings handle used by
# the Setnayan-tier 999/day SKU. Generated once via a separate admin
# tool; do NOT confuse with the per-event Personal-tier grants stored in
# patiktok_oauth_grants.
TIKTOK_SETNAYAN_REFRESH_TOKEN=

# ----------------------------------------------------------------------
# Iteration 0011 — Panood YouTube OAuth (per-couple BYO YouTube)
# ----------------------------------------------------------------------
# Shipped 2026-05-16 alongside the V1 scope expansion that wires real
# OAuth on the V1.5+ scaffold setup pages (CLAUDE.md decision log row
# 2026-05-16, "OAuth wiring for V1.5+ scaffold setup pages shipped early").
#
# Owner setup (BLOCKING for live broadcasts; the page degrades to a
# "coming soon — admin setup pending" placeholder until these are set):
#   1. Create a Google Cloud project + enable YouTube Data API v3.
#   2. Configure the OAuth consent screen (External, Production).
#   3. Submit for Google verification — review window is 1-4 weeks.
#   4. Create an OAuth 2.0 Client ID (Web application).
#   5. Add the callback below as an authorized redirect URI.
#   6. Paste the credentials below; redeploy.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=https://www.setnayan.com/api/oauth/youtube/callback

# Shared CRON secret for the access-token refresh worker
# /api/cron/oauth-refresh. The same secret is reused for the Drive
# (iteration 0012 Papic) refresh sweep — wired 2026-05-16.
# Generate with: openssl rand -hex 32
OAUTH_REFRESH_CRON_SECRET=

# ----------------------------------------------------------------------
# Iteration 0012 — Papic Google Drive OAuth (per-couple BYO Drive)
# ----------------------------------------------------------------------
# Shipped 2026-05-16 alongside the V1 scope expansion that wires real
# OAuth on the V1.5+ scaffold setup pages (CLAUDE.md decision log row
# 2026-05-16, "OAuth wiring for V1.5+ scaffold setup pages shipped early").
#
# Owner setup (BLOCKING for the "Use my Google Drive only" storage
# option; the Papic setup page degrades the Drive radio to a "coming
# soon — admin setup pending" placeholder until these are set, while
# the Setnayan-R2 default option remains fully functional):
#   1. SAME Google Cloud project as YouTube — Drive and YouTube can
#      share the same OAuth client (the redirect URI distinguishes
#      them). Or use a separate client if you want separate quota /
#      review tracking.
#   2. Enable Google Drive API v3 in the Google Cloud project.
#   3. Add the `https://www.googleapis.com/auth/drive.file` scope to
#      the OAuth consent screen (narrowest scope — only files Setnayan
#      creates in the couple's Drive, NOT full Drive access).
#   4. Submit for Google verification if not already verified.
#   5. Create an OAuth 2.0 Client ID (Web application) or reuse the
#      YouTube one.
#   6. Add the callback below as an authorized redirect URI.
#   7. Paste the credentials below; redeploy.
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://www.setnayan.com/api/oauth/drive/callback

# ----------------------------------------------------------------------
# Iteration 0009 — Photo Delivery Drive OAuth (separate redirect URI)
# ----------------------------------------------------------------------
# Photo Delivery (0009) reuses the SAME Google OAuth client as Papic
# (0012) — both want `drive.file` scope — but registers a SECOND
# authorized redirect URI so Google can route the consent callback
# back to the right iteration. The /api/oauth/photo-delivery/start
# route returns 503 ("coming soon — admin setup pending") until this
# var is set, while the dashboard panel stays functional in idle state.
#
# Owner setup:
#   1. Reuse the existing Google Drive OAuth client created for Papic.
#   2. Add the callback below to the client's "Authorized redirect URIs"
#      list in Google Cloud Console — does NOT replace the Papic URI,
#      both coexist on the same client.
#   3. Paste below + into Vercel env vars (Production, Preview, Development).
PHOTO_DELIVERY_OAUTH_REDIRECT_URI=https://www.setnayan.com/api/oauth/photo-delivery/callback

# ----------------------------------------------------------------------
# At-rest encryption key — used by apps/web/lib/encryption.ts
# ----------------------------------------------------------------------
# AES-256-GCM key for encrypting OAuth refresh tokens (and any future
# small server-side secrets) before persisting to Postgres TEXT columns.
# First consumer: iteration 0009 Photo Delivery —
# `events.photo_delivery_oauth_token_encrypted`.
#
# Owner setup:
#   1. Generate: `openssl rand -base64 32` → 44-char base64 string.
#   2. Paste below + into Vercel env vars (Production, Preview, Development).
#   3. Rotate by re-encrypting all `*_oauth_token_encrypted` columns under
#      the new key in a one-shot migration (no rotation script ships in
#      V1 — manual when needed).
ENCRYPTION_KEY=

# ----------------------------------------------------------------------
# Admin add-ons — Vendor add-ons tab feature flag (Phase 3 nav)
# ----------------------------------------------------------------------
# Vendor add-ons (the second tab in /admin/addons) is deferred per
# CLAUDE.md 2026-05-28 14th row § 6 V1.x list. Setting this flag to '1'
# surfaces the Vendor tab; leaving it unset (default) suppresses the tab
# entirely so admins don't see a dead "Coming soon" affordance during
# pilot per [[feedback_setnayan_no_dev_text_post_launch]].
#
# Owner setup:
#   1. Leave unset for V1 pilot.
#   2. Set to '1' in Vercel env vars when the Vendor add-ons grid lands
#      with the next refresh.
NEXT_PUBLIC_VENDOR_ADDONS_ENABLED=

# ----------------------------------------------------------------------
# Vendor favorites subscription gate (owner-locked 2026-07-18)
# ----------------------------------------------------------------------
# When 'true', a vendor is shown as a favorite / saved only while they hold an
# active PAID subscription (Solo+). A lapse to a free tier hides their card from
# every couple/coordinator saved list immediately; the favorite rows are never
# deleted, so the card returns on re-subscribe. Server-only (no NEXT_PUBLIC_).
# Owner setup:
#   1. Leave unset — MUST stay OFF during free-during-launch (every vendor is
#      free then, so an active gate would blank the marketplace favorites).
#   2. Set to 'true' in Vercel env vars only once paid vendor subscriptions are
#      mandatory (owner sign-off on activation timing pending).
VENDOR_FAVORITES_SUBSCRIPTION_GATE=

# ----------------------------------------------------------------------
# V2 Cutover Phase G — IndexedDB + service-worker offline daemon
# ----------------------------------------------------------------------
# Scaffolds offline-capture queues for the 7 media services (Papic,
# Panood, Patiktok, Pabati, SDE, Camera Bridge, Live Wall) per
# CLAUDE.md 2026-05-28 third row. Phase G ships scaffolding only —
# per-service upload handlers stub to `{ ok: false, error: 'V1.x
# post-pilot' }` and the queues stay empty until V1.x wires real upload
# paths.
#
# Default OFF for pilot so the 5-20 family cohort doesn't get surprised
# by a second service worker (alongside the existing /sw.js asset
# cache) or by a Background Sync API permission prompt.
#
# Owner setup:
#   1. Leave unset (or 'false') for V1 pilot.
#   2. Set to 'true' in dev or V1.x to mount the daemon, register
#      /sw-offline.js, and arm Background Sync. The admin diagnostic
#      lives at /admin/offline regardless of the flag — the page itself
#      surfaces "Daemon disabled" status when the flag is off.
# NEXT_PUBLIC_OFFLINE_DAEMON_ENABLED=

# ----------------------------------------------------------------------
# Social auto-publish — Meta (Facebook Page + Instagram) Graph API
# ----------------------------------------------------------------------
# The social auto-publish pipeline (corpus
# 03_Strategy/Social_Sharing_Program_2026-06-12.md § 8 · lib/social/*)
# posts to the Setnayan Facebook Page (Phase A) and Instagram feed
# (Phase B). Leave all three unset for the manual copy-paste workflow;
# the admin Social Queue still composes + schedules drafts, but nothing
# dispatches until the env lands and the master switch is flipped on at
# /admin/social-queue.
#
#   META_PAGE_ID           — the Setnayan Facebook Page id.
#   META_PAGE_ACCESS_TOKEN — a long-lived Page access token. Needs
#                            pages_manage_posts for Facebook, plus
#                            instagram_basic + instagram_content_publish
#                            + pages_show_list for Instagram. The SAME
#                            token authorizes both surfaces.
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
#   IG_USER_ID — the Instagram Business account id linked to the
#                Setnayan Page (Meta Business Suite → Instagram account
#                → linked Page). Required ONLY for Instagram publishing;
#                Facebook works with just the two vars above. The card
#                route renders a public 1080×1080 JPEG that IG fetches at
#                publish time (IG rejects text-only posts).
IG_USER_ID=
#   TIKTOK_ACCESS_TOKEN — per-account OAuth USER token for the Setnayan
#                TikTok account (Phase C · lib/social/tiktok.ts). Posts the
#                branded 9:16 card as a Content Posting API PHOTO-mode post.
#                NOT the couple-BYO Patiktok vars above. Requires: the
#                Content Posting API audit (an unaudited app can only post
#                privately) + the video.publish / photo scope + a verified
#                PULL_FROM_URL domain in the TikTok dev portal (so TikTok can
#                pull the card image). Leave unset for the ASSISTED-MANUAL
#                lane (download the card + copy the caption from the admin
#                Social Queue). Tokens are short-lived — refresh wiring is a
#                follow-on. See API_Integration_Checklist #21c.
TIKTOK_ACCESS_TOKEN=

# ----------------------------------------------------------------------
# Vendor Instagram connect + sync — "Instagram API with Instagram Login"
# ----------------------------------------------------------------------
# Per-VENDOR OAuth (lib/vendor-instagram.ts · /api/vendor/instagram/*) so a
# vendor can connect their OWN Business/Creator Instagram account and sync
# recent posts into their public portfolio. Uses the "Instagram API with
# Instagram Login" product — NO Facebook Page required (better for PH vendors).
# DISTINCT from the META_* auto-publish vars above (that flow posts as the
# Setnayan Page; this flow authorizes each vendor's own account).
#
# Leave BOTH unset to keep the whole IG-connect feature INERT: the /connect
# route returns a friendly 503 and the vendor UI shows a "coming soon" card.
# These are currently UNSET in prod.
#
#   IG_APP_ID     — the Instagram app's own App ID (Meta App Dashboard →
#                   the Instagram-Login product, NOT the Facebook App ID).
#   IG_APP_SECRET — the Instagram app's own App Secret.
IG_APP_ID=
IG_APP_SECRET=
#   META_IG_OAUTH_REDIRECT_URI — OPTIONAL override for the OAuth callback.
#                   Defaults to <request-origin>/api/vendor/instagram/callback
#                   (e.g. https://www.setnayan.com/api/vendor/instagram/callback).
#                   Register that URL under the product's "Valid OAuth Redirect
#                   URIs". Set this only if the request origin differs from the
#                   canonical registered host.
META_IG_OAUTH_REDIRECT_URI=

# ----------------------------------------------------------------------
# Account-level face profile — opt-in cross-event face reuse (RA 10173)
# ----------------------------------------------------------------------
# ⚠ BIOMETRIC = SENSITIVE PERSONAL INFO. Owner-locked 2026-06-26 reversal
# of per-event face scoping: a person's face profile can live on their
# Setnayan ACCOUNT and be reused to tag THEM faster across any event they
# attend. Strictly opt-in, OFF by default, only ever used to recognize the
# profile's OWNER (never a cross-person search index), with one-tap
# account-level erasure ("forget my face everywhere").
#
# Leave UNSET (the whole feature is dormant — no code reads/writes the
# user_face_profiles table). Set to 'true' ONLY after the DPO has signed
# off on the consent copy + retention policy. Read by both the consent UI
# (dashboard/profile) and the server-side matcher seed, so there is one
# source of truth.
NEXT_PUBLIC_ACCOUNT_FACE_PROFILE_ENABLED=

# 3D Booth Ads · Part C (slice 9) — when 'true', Pro/Enterprise vendors get a public
# shareable "Walk into my booth" 3D showcase at /v/[slug]/booth (+ the button on their
# profile). Off → the route 404s and the button hides. Flip after eyeballing the booth.
NEXT_PUBLIC_PLAN3D_BOOTH_SHOWCASE=

# 3D Booth Ads · Part B (slice 9) — when 'true', the PUBLIC homepage "Maria & Jose"
# 3D demo fills its booths with REAL marketplace vendors on rotation (Pro/Enterprise
# ranked first + ad/token boosts = more airtime; everyone eligible cycles in). SEPARATE
# from Part A — the public homepage is more sensitive, so it flips on its own. Default
# OFF → the demo shows its normal sample booths.
NEXT_PUBLIC_PLAN3D_DEMO_ADS=

# 3D Booth Ads · Part A (slice 9) — when 'true', the couple's 3D seating lab shows
# dashed "ghost booths" for vendor categories they haven't booked; tapping one
# opens that category's marketplace grid. Couple-lab ONLY (never guest pages).
# Default OFF → byte-identical. Flip only AFTER the ghost_booths_prefs migration
# is applied. Owner-tweakable inventory: GHOST_BOOTH_CATEGORIES in lib/ghost-booths.ts.
NEXT_PUBLIC_PLAN3D_BOOTH_ADS=

# 3D Plan "shared room" (slice 8) — when 'true', 2+ people online on the same
# event's 3D map see each other's characters walk in real time and can "say hi".
# Default OFF → byte-identical single-player. Flip to 'true' only after a real
# 2-device test (the multiplayer path can't be verified in CI). Public channel
# scoped by the event's unguessable UUID; no PII on the wire (name + colour only).
NEXT_PUBLIC_PLAN3D_SHARED_ROOM=

# Claude API — vendor deep-search analytics on /admin/verify (2026-07-03).
# Get a key at platform.claude.com; without it the "Run deep search" button
# fails gracefully with a clear message.
ANTHROPIC_API_KEY=

# Coordinator P2 — filtered run-of-show (2026-07-20). When 'true', the couple
# schedule page gains the responsible-party editor + per-vendor/guest view
# lenses + bulk retime + wedding run-of-show templates, and vendor-tagged rows
# rank 'primary' on the vendor Brief. Default OFF → today's behavior exactly.
# Flip ONLY AFTER pushing migration 20270825042743 (responsible-party columns).
NEXT_PUBLIC_SCHEDULE_ROS_P2_ENABLED=

# Coordinator P3 — day-of broadcast + email call-times (2026-07-20). When
# 'true', the day-of grid's broadcast card goes live: couple/coordinator
# compose broadcasts every event member sees, plus an "Email call-times to
# vendors" action (earliest responsible-tagged schedule block per vendor,
# email-only via Resend — no key configured = clean no-op). Default OFF →
# the card keeps its pre-P3 "Coming soon" stub exactly. Flip ONLY AFTER
# pushing migration 20270825364600 (coordinator_broadcasts).
NEXT_PUBLIC_COORDINATOR_P3_ENABLED=

# Guest run-of-show trigger read (owner directive 2026-07-23). When 'true' (or
# '1'), the guest "What's happening now" surfaces (/[slug] GuestHubCard
# "Coming up", the /[slug]/hub Now panel, ScheduleWidget badges) follow the
# host/coordinator-set run_state pointer once the show has started (wall clock
# stays the fallback before that), and the RSVP-season schedule renders an
# "Estimated program" label. Default OFF → guest surfaces keep today's pure
# wall-clock inference. The flag exists only to sequence against the 5-tab
# open-browse hub rebuild (it re-homes these exact panels); the host/coordinator
# WRITE side (advance_schedule_block + widened delegate gate, migration
# 20270917100000) is live regardless.
NEXT_PUBLIC_GUEST_NOW_TRIGGER=

# Promo free windows — admin-scheduled "these services are free this weekend"
# announcements (owner ask 2026-07-22 · /admin/pricing → Free windows tab). When
# 'true', a live promo_free_windows row makes its covered couple SKUs resolve as
# owned for every couple during its date range (via the entitlement-OR in
# lib/entitlements.ts) and shows the couple an in-app banner. Server-only (the
# gate + banner are server-side) — NOT NEXT_PUBLIC. Default OFF → windows can be
# authored but free nothing and show no banner. Flip ONLY AFTER pushing migration
# 20270908268882 (promo_free_windows). Covers BOTH audiences: couples (chosen SKUs
# resolve as owned) and vendors (every vendor promoted to a paid tier for free via
# resolveVendorTier). The vendor path is additionally inert until paid vendor
# billing is on (VENDOR_TIER_FEATURE_GATE) — before that all vendors are free anyway.
PROMO_FREE_WINDOWS_ENABLED=
