{
  "name": "setnayan",
  "private": true,
  "version": "0.0.1",
  "description": "Setnayan — Philippines-first life-events platform. V1 weddings.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "tauri:icons": "cargo tauri icon src-tauri/icons/icon.svg",
    "tauri:dev": "pnpm --filter @setnayan/web dev & cargo tauri dev",
    "tauri:build": "pnpm tauri:icons && cargo tauri build"
  },
  "devDependencies": {
    "turbo": "^2.9.14",
    "typescript": "^5.7.0",
    "prettier": "^3.3.3"
  }
}
